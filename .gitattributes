# 全部脚本/配置强制 LF：避免 Windows 编辑导致 Linux bash 报 \r 语法错误
* text=auto eol=lf

*.sh        text eol=lf
*.fish      text eol=lf
*.bash      text eol=lf
*.toml      text eol=lf
*.conf      text eol=lf
*.jsonc     text eol=lf
*.json      text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.txt       text eol=lf
*.md        text eol=lf

# ~/.local/bin 工具脚本（无后缀）
kde-dotfiles/.local/bin/*    text eol=lf

# 二进制
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.zip       binary
*.tar.gz    binary
