#!/usr/bin/env bash
# xf-self-update — 拉取 xynrin-fedora 最新仓库并重新部署 dotfiles
# Usage:
#   xf-self-update            # 拉最新主分支，强刷 dotfiles + xf-* 工具
#   xf-self-update --dry-run  # 只看会改什么
#   xf-self-update --only terminal,kde-theme  # 只重跑某些模块
#   xf-self-update --branch dev  # 切到其他分支

set -euo pipefail

BRANCH="main"
ONLY=""
DRY=0
ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        --branch) BRANCH="$2"; shift 2 ;;
        --only)   ONLY="$2"; ARGS+=(--only "$2"); shift 2 ;;
        --dry-run) DRY=1; ARGS+=(--dry-run); shift ;;
        --all)    ARGS+=(--all); shift ;;
        -h|--help)
            grep '^#' "$0" | sed 's/^# \?//' | head -n 12
            exit 0 ;;
        *) ARGS+=("$1"); shift ;;
    esac
done

TARGET_DIR="${XF_TARGET_DIR:-/tmp/xynrin-fedora}"

C1='\033[1;35m'; C2='\033[1;36m'; C3='\033[1;32m'; CY='\033[1;33m'; NC='\033[0m'
info() { printf "${C2}==>${NC} %s\n" "$*"; }
ok()   { printf "${C3}  ✓${NC} %s\n" "$*"; }
warn() { printf "${CY}  !${NC} %s\n" "$*"; }

[[ $EUID -eq 0 ]] && { echo "请以普通用户运行（脚本内部会按需 sudo）" >&2; exit 1; }
[[ -f /etc/fedora-release ]] || { echo "仅支持 Fedora" >&2; exit 1; }

info "拉取 xynrin-fedora（branch: $BRANCH）"

# 优先用 git，回落到 tarball
if [[ -d "$TARGET_DIR/.git" ]]; then
    info "已有仓库，git pull"
    git -C "$TARGET_DIR" fetch origin "$BRANCH"
    git -C "$TARGET_DIR" checkout "$BRANCH"
    git -C "$TARGET_DIR" reset --hard "origin/$BRANCH"
elif command -v git >/dev/null 2>&1; then
    info "首次拉取（git clone）"
    rm -rf "$TARGET_DIR"
    git clone --depth 1 --branch "$BRANCH" \
        https://github.com/Xynrin/xynrin-fedora.git "$TARGET_DIR"
else
    info "无 git，回落 tarball（不能切分支）"
    [[ "$BRANCH" != "main" ]] && warn "无 git，--branch 被忽略"
    rm -rf "$TARGET_DIR"
    mkdir -p "$TARGET_DIR"
    curl -fsSL "https://github.com/Xynrin/xynrin-fedora/archive/refs/heads/$BRANCH.tar.gz" \
        | tar -xz -C "$TARGET_DIR" --strip-components=1
fi

ok "仓库就绪: $TARGET_DIR"

# 显示新旧版本
new_ver="(unknown)"
[[ -f "$TARGET_DIR/VERSION" ]] && new_ver=$(cat "$TARGET_DIR/VERSION")
old_ver="(unknown)"
[[ -f "$HOME/.config/xynrin-fedora/VERSION" ]] && old_ver=$(cat "$HOME/.config/xynrin-fedora/VERSION")
info "版本: $old_ver → $new_ver"

if [[ -z "$ONLY" ]] && [[ ! " ${ARGS[*]:-} " =~ " --all " ]]; then
    # 默认更新场景：只重跑 terminal + kde-theme，不重新装一遍 apps
    ARGS+=(--only "terminal,kde-theme,fonts-cjk")
    info "默认只重跑 dotfiles 相关模块（terminal/kde-theme/fonts-cjk）"
    info "想全量重跑：xf-self-update --all"
fi

chmod +x "$TARGET_DIR/install.sh" "$TARGET_DIR/scripts/"*.sh
exec "$TARGET_DIR/install.sh" "${ARGS[@]}"
