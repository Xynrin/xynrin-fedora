#!/usr/bin/env bash
# xf-help — fzf 驱动的命令速查 TUI
#   xf-help            弹 TUI（数据源：docs/COMMANDS.md）
#   xf-help xf-update  直接打印某条
#   xf-help --list     纯文本列所有命令
#
# 数据源查找顺序：
#   1) $XF_DOCS_FILE（环境变量，可手动指定）
#   2) /tmp/xynrin-fedora/docs/COMMANDS.md（bootstrap 默认目录）
#   3) ~/.config/xynrin-fedora/COMMANDS.md（部署副本）
#   4) 在线 raw.githubusercontent.com（最后兜底）

set -euo pipefail

C1='\033[1;35m'; C2='\033[1;36m'; C3='\033[1;32m'; CY='\033[1;33m'; DIM='\033[2m'; NC='\033[0m'

VERSION="${XF_VERSION:-}"
[[ -z "$VERSION" && -f "$HOME/.config/xynrin-fedora/VERSION" ]] && VERSION=$(cat "$HOME/.config/xynrin-fedora/VERSION")
[[ -z "$VERSION" && -f /tmp/xynrin-fedora/VERSION ]] && VERSION=$(cat /tmp/xynrin-fedora/VERSION)
[[ -z "$VERSION" ]] && VERSION="dev"

# ===== 找数据源 =====
locate_docs() {
    local candidates=(
        "${XF_DOCS_FILE:-}"
        "/tmp/xynrin-fedora/docs/COMMANDS.md"
        "$HOME/.config/xynrin-fedora/COMMANDS.md"
    )
    for f in "${candidates[@]}"; do
        [[ -n "$f" && -f "$f" ]] && { echo "$f"; return 0; }
    done
    # 在线兜底：缓存到 ~/.cache
    local cache="$HOME/.cache/xynrin-fedora/COMMANDS.md"
    mkdir -p "$(dirname "$cache")"
    if curl -fsSL "https://raw.githubusercontent.com/Xynrin/xynrin-fedora/main/docs/COMMANDS.md" -o "$cache.tmp" 2>/dev/null; then
        mv "$cache.tmp" "$cache"
        echo "$cache"
        return 0
    fi
    return 1
}

DOCS=$(locate_docs) || {
    echo "找不到 COMMANDS.md（在 \$XF_DOCS_FILE / /tmp/xynrin-fedora/docs/ / ~/.config/xynrin-fedora/ / 在线 都没找到）" >&2
    echo "建议跑：xf-self-update 重新部署文档" >&2
    exit 1
}

# ===== 提取所有 ## 标题（命令名） =====
# 跳过文档自身的"目录""安装入口（参考）""故障排查"等元章节，只列 xf-* 和 install/bootstrap
list_commands() {
    awk '
        /^## / {
            name = $0
            sub(/^## /, "", name)
            # 过滤元章节：只列入口命令名 xynrin / up / xf-* / bootstrap / install
            if (name ~ /^(xf-|bootstrap|install|xynrin|up)$|^(xf-|bootstrap|install)/) print name
        }
    ' "$DOCS"
}

# ===== 提取某个标题对应的章节内容 =====
extract_section() {
    local name="$1"
    awk -v target="## $name" '
        $0 == target { capture=1; print; next }
        capture && /^## / { exit }
        capture && /^---$/ { next }   # 去掉分割线
        capture { print }
    ' "$DOCS"
}

# ===== 渲染章节（有 bat 用 bat md 高亮，没有就 cat）=====
render_section() {
    local name="$1" content
    content=$(extract_section "$name")
    [[ -z "$content" ]] && { echo "(无说明，请检查 docs/COMMANDS.md)"; return; }
    if command -v bat >/dev/null 2>&1; then
        echo "$content" | bat --plain --language=md --color=always --theme=base16 2>/dev/null \
            || echo "$content"
    elif command -v glow >/dev/null 2>&1; then
        echo "$content" | glow -s dark -
    else
        echo "$content"
    fi
}

# ===== 直接打印模式 =====
case "${1:-}" in
    --render-preview)
        # fzf preview 内部调用，渲染单个章节，不进 TUI
        shift
        render_section "$*"
        exit 0 ;;
    --list|-l)
        list_commands
        exit 0 ;;
    --version|-v)
        echo "xf-help (xynrin-fedora $VERSION)"
        exit 0 ;;
    -h|--help)
        cat <<EOF
xf-help — xynrin-fedora 命令速查 TUI

用法:
    xf-help                弹 fzf TUI
    xf-help <command>      直接打印某条命令的说明
    xf-help --list         纯文本列所有命令
    xf-help --version      版本号

数据源: $DOCS
EOF
        exit 0 ;;
    "")
        : ;;  # 进 TUI
    *)
        # 直接打印某条
        render_section "$1"
        exit 0 ;;
esac

# ===== TUI =====
command -v fzf >/dev/null 2>&1 || {
    echo "fzf 未安装。备选：xf-help --list 或 xf-help <name>" >&2
    exit 1
}

# bash 4 才有 -p 提示，避免兼容问题用 read -r
choice=$(
    list_commands | fzf \
        --layout=reverse \
        --border=rounded \
        --border-label="  xynrin-fedora $VERSION · 命令速查  " \
        --border-label-pos=3 \
        --info=inline-right \
        --prompt="❯ " \
        --header="↑↓ 选择 · 输入搜索 · Enter 看详情 · Ctrl-Y 复制名 · Esc 退出" \
        --preview "bash $0 --render-preview {}" \
        --preview-window=right:60%:wrap \
        --bind "ctrl-y:execute-silent(echo -n {} | (wl-copy 2>/dev/null || xclip -sel clip 2>/dev/null || pbcopy 2>/dev/null))+abort" \
        --color="fg:#cdd6f4,bg:-1,hl:#f9e2af,fg+:#cdd6f4,bg+:#313244,hl+:#f9e2af" \
        --color="info:#89b4fa,prompt:#cba6f7,pointer:#cba6f7,marker:#a6e3a1,spinner:#94e2d5" \
        --color="header:#94e2d5,border:#cba6f7,label:#f5c2e7,preview-border:#585b70" \
        --pointer="❯" \
        --height=80%
) || exit 0

[[ -z "$choice" ]] && exit 0

# Enter 后：清屏 + 显示完整章节，并提示是否运行
clear
render_section "$choice"
echo ""
echo -e "${DIM}────────────────────────────────────────${NC}"
# 只对 xf-* 命令提供"立即运行"
if [[ "$choice" == xf-* ]] && command -v "$choice" >/dev/null 2>&1; then
    read -r -p "$(printf "${C2}❯${NC} 现在运行 ${C3}%s${NC}？ [y/N] " "$choice")" ans
    if [[ "$ans" =~ ^[Yy]$ ]]; then
        echo ""
        exec "$choice"
    fi
fi
